                <mxCell id="60" value="&lt;div style=&quot;color: #dcd7ba;background-color: #1f1f28;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #727169;&quot;&gt;// PS - Writr a program which accept on e number from the user and print that number of even numbers on screen.&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;#&lt;/span&gt;&lt;span style=&quot;color: #957fb8;&quot;&gt;include&lt;/span&gt;&lt;span style=&quot;color: #98bb6c;&quot;&gt;&amp;lt;stdio.h&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #957fb8;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #7e9cd8;&quot;&gt;printEven&lt;/span&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #957fb8;&quot;&gt;int&lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt;iNo&lt;/span&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;{&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #957fb8;&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt;iNo&lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #c0a36e;&quot;&gt;&amp;lt;=&lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d27e99;&quot;&gt;0&lt;/span&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #9c