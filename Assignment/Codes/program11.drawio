 &lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt;iEven&lt;/span&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #957fb8;&quot;&gt;int&lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #7e9cd8;&quot;&gt;main&lt;/span&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;()&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;{&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #957fb8;&quot;&gt;int&lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt;iValue&lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #c0a36e;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d27e99;&quot;&gt;0&lt;/span&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #7e9cd8;&quot;&gt;printf&lt;/span&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #98bb6c;&quot;&gt;&quot;Enter number: &lt;/span&gt;&lt;span style=&quot;color: #7fb4ca;&quot;&gt;\n&lt;/span&gt;&lt;span style=&quot;color: #98bb6c;&quot;&gt;&quot;&lt;/span&gt;&lt;span style=&quot;color: #9cabca;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #dcd7ba;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #7e9cd8;&quot;&gt;scanf&lt;/span&g